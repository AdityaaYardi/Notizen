# Copy this file to .streamlit/secrets.toml (local) or paste its contents
# into Streamlit Cloud -> App -> Settings -> Secrets (deployed).
# NEVER commit the real secrets.toml — it contains your token.

[github]
token = "ghp_YOUR_PERSONAL_ACCESS_TOKEN"
repo = "AdityaaYardi/Notizen"
branch = "data"       # tasks are stored on this branch (not main, so saves don't redeploy the app)
path = "tasks.json"
